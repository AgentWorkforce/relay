# Source code (TypeScript)
src/

# Rust source code (we ship pre-built binaries in bin/)
src/*.rs

# Tmux binary (users should install system tmux)
bin/tmux

# Trajectories (development artifacts)
.trajectories/

# Source maps (not needed for production)
**/*.js.map
**/*.d.ts.map

# Documentation (link to GitHub instead)
docs/

# Development scripts (except postinstall.js which is needed)
scripts/cloud-setup.sh
scripts/dev/
scripts/e2e-test.sh
scripts/games/
scripts/manual-qa.sh
scripts/run-cloud-qa.sh
scripts/test-cli-auth/
