{
  "name": "@agent-relay/harness-driver",
  "version": "7.1.1",
  "description": "Managed harness driver for Agent Relay — attach, wrap, spawn, inject, and observe agent runtimes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js",
      "default": "./dist/protocol.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js",
      "default": "./dist/actions.js"
    },
    "./broker-path": {
      "types": "./dist/broker-path.d.ts",
      "import": "./dist/broker-path.js",
      "default": "./dist/broker-path.js"
    },
    "./harnesses": {
      "types": "./dist/harnesses.d.ts",
      "import": "./dist/harnesses.js",
      "default": "./dist/harnesses.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-relay/sdk": "7.1.1",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@agent-relay/broker-darwin-arm64": "7.1.1",
    "@agent-relay/broker-darwin-x64": "7.1.1",
    "@agent-relay/broker-linux-arm64": "7.1.1",
    "@agent-relay/broker-linux-x64": "7.1.1",
    "@agent-relay/broker-win32-x64": "7.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentWorkforce/relay.git",
    "directory": "packages/harness-driver"
  },
  "license": "Apache-2.0"
}
