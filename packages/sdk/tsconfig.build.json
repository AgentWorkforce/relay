{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@agent-relay/config": ["../config/dist/index.d.ts"],
      "@agent-relay/config/*": ["../config/dist/*"],
      "@agent-relay/cloud": ["../cloud/dist/index.d.ts"],
      "@agent-relay/cloud/*": ["../cloud/dist/*"],
      "@agent-relay/github-primitive": ["../github-primitive/dist/index.d.ts"],
      "@agent-relay/slack-primitive": ["../slack-primitive/dist/index.d.ts"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src/index.ts",
    "src/capabilities.ts",
    "src/relaycast-errors.ts",
    "src/messaging/**/*.ts",
    "src/delivery/**/*.ts",
    "src/actions/**/*.ts"
  ],
  "exclude": ["src/__tests__/**"]
}
