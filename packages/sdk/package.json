      "optional": true
    },
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@google/adk": {
      "optional": true
    },
    "@langchain/langgraph": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@openai/agents": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "crewai": {
      "optional": true
    }
  }
}
