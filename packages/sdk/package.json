{
  "name": "@agent-relay/sdk",
  "version": "9.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./messaging": {
      "types": "./dist/messaging/index.d.ts",
      "import": "./dist/messaging/index.js",
      "default": "./dist/messaging/index.js"
    },
    "./delivery": {
      "types": "./dist/delivery/index.d.ts",
      "import": "./dist/delivery/index.js",
      "default": "./dist/delivery/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js",
      "default": "./dist/actions/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.js",
      "default": "./dist/session/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities.d.ts",
      "import": "./dist/capabilities.js",
      "default": "./dist/capabilities.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentWorkforce/relay.git",
    "directory": "packages/sdk"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && npx tsc -p tsconfig.build.json",
    "build:full": "npm run build",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src/__tests__/agent-relay.test.ts src/__tests__/facade.test.ts src/__tests__/listeners.test.ts src/__tests__/integrations.test.ts src/__tests__/messaging.test.ts src/__tests__/delivery-actions.test.ts src/__tests__/relaycast-errors.test.ts src/__tests__/register-action-relay.test.ts src/__tests__/typed-action-handle.test.ts src/__tests__/webhooks.test.ts",
    "test:types": "vitest run --typecheck.only --typecheck.tsconfig tsconfig.typetest.json",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.13.10"
  },
  "dependencies": {
    "@relaycast/sdk": "^4.1.6"
  }
}
