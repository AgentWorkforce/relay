{
  "name": "@agent-relay/cloud",
  "version": "3.2.15",
  "description": "Cloud SDK for Agent Relay — auth, workflow execution, and provider connections",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
