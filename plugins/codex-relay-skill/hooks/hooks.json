{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/codex-relay-skill/hooks/session-start.sh",
            "timeoutSec": 15,
            "statusMessage": "Connecting Relaycast"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/codex-relay-skill/hooks/prompt-inbox.sh",
            "timeoutSec": 5,
            "statusMessage": "Checking relay inbox"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/codex-relay-skill/hooks/stop-inbox.sh",
            "timeoutSec": 5,
            "statusMessage": "Verifying relay inbox"
          }
        ]
      }
    ]
  }
}
