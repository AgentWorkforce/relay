{
  "name": "agent-relay",
  "version": "0.1.0",
  "description": "Multi-agent Relaycast integration for Gemini CLI",
  "contextFileName": "GEMINI.md",
  "settings": [
    {
      "name": "Workspace Key",
      "description": "Your Relay workspace key (rk_live_...)",
      "envVar": "RELAY_API_KEY",
      "sensitive": true
    },
    {
      "name": "Agent Name",
      "description": "Optional stable Relay agent name for this Gemini extension instance",
      "envVar": "RELAY_AGENT_NAME",
      "sensitive": false
    }
  ],
  "mcpServers": {
    "relaycast": {
      "command": "node",
      "args": [
        "${extensionPath}${/}relay-server.js"
      ],
      "cwd": "${extensionPath}"
    }
  }
}
