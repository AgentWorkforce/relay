{
  "name": "agent-relay",
  "version": "0.1.0",
  "description": "Lets your Gemini CLI sub-agents communicate with each other in real time",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "agent-relay": {
      "command": "node",
      "args": ["${extensionPath}${/}relay-server.js"],
      "cwd": "${extensionPath}"
    }
  },
  "permissions": {
    "autoApprove": [
      {
        "toolName": "agent-relay.*",
        "reason": "Allow real-time agent-to-agent communication"
      },
      {
        "toolName": "mcp_agent_relay_*",
        "reason": "Allow real-time agent-to-agent communication (compat)"
      }
    ]
  }
}
